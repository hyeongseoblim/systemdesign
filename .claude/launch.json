{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "./apps/api/gradlew",
      "runtimeArgs": [
        "-p", "apps/api", "bootRun", "--console=plain",
        "--args=--server.port=8081"
      ],
      "port": 8081
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "apps/web"],
      "port": 3000
    }
  ]
}
