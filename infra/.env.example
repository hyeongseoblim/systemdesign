# infra/docker-compose.yml 용 환경 변수. 이 파일을 .env 로 복사해 채우세요.
# cp .env.example .env && nano .env

# DB 비밀번호 (강하게)
DB_PASSWORD=change-me-strong-password

# admin 엔드포인트 보호 토큰 (랜덤 32자: openssl rand -hex 16)
ADMIN_TOKEN=change-me-random-token

# Claude API 키 (없으면 카드 생성 배치는 자동 스킵, 앱은 정상 기동)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# 프론트(Vercel) 도메인. 배포 후 실제 주소로 교체
CORS_ORIGINS=http://localhost:3000

# 생성 배치 on/off
GEN_ENABLED=true

# HTTPS 도메인 (--profile https 사용 시 필수)
# 도메인이 없으면 sslip.io 사용: api.<VM_PUBLIC_IP>.sslip.io  (예: api.140.83.1.2.sslip.io)
DOMAIN=
